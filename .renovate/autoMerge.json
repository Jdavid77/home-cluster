{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Auto-merge trusted OCI digests",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "matchPackageNames": ["/home-operations/"],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false,
      "schedule": ["after 1am and before 7am"]
    },
    {
      "description": "Auto-merge high-cadence OCI packages weekly",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["/kube-prometheus-stack/"],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false,
      "schedule": ["before 6am on Monday"]
    },
    {
      "description": "Auto-merge Otel Collector updates",
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false,
      "matchUpdateTypes": ["minor", "patch"],
      "packageNames": [
        "/opentelemetry-operator/",
        "/opentelemetry-collector-releases/"
      ],
      "schedule": ["after 1am and before 7am"]
    },
    {
      "description": "Auto-merge GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "minimumReleaseAge": "3 days",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge trusted GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["/^actions\\//", "/^renovatebot\\//"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "minimumReleaseAge": "1 minute",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge Grafana dashboards",
      "matchDatasources": ["custom.grafana-dashboards"],
      "matchUpdateTypes": ["major"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge Renovate Presets",
      "matchManagers": ["renovate-config"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true
    }
  ]
}
